# Database connection string (MySQL/TiDB)
DATABASE_URL=mysql://user:password@host:4000/database?ssl={"rejectUnauthorized":true}

# Secret for signing JWT session tokens (any random 32+ char string)
JWT_SECRET=change-me-to-a-random-secret-string

# Secret for authenticating cron job requests
CRON_SECRET=change-me-to-another-random-string

# Server port (optional, defaults to 3000)
# PORT=3000
